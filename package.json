    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.10"
  }
